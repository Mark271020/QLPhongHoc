@model QLPhongHoc.Models.PhongHoc

@{
    ViewData["Title"] = "Sửa phòng học";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header bg-warning">
                <h4 class="mb-0"><i class="fas fa-edit"></i> Sửa thông tin phòng học</h4>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />
                    
                    <div class="mb-3">
                        <label asp-for="TenPhong" class="form-label fw-bold"></label>
                        <input asp-for="TenPhong" class="form-control" />
                        <span asp-validation-for="TenPhong" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="ViTri" class="form-label fw-bold"></label>
                        <input asp-for="ViTri" class="form-control" />
                        <span asp-validation-for="ViTri" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="SucChua" class="form-label fw-bold"></label>
                        <input asp-for="SucChua" class="form-control" type="number" />
                        <span asp-validation-for="SucChua" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="TrangThietBi" class="form-label fw-bold"></label>
                        <textarea asp-for="TrangThietBi" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="TrangThietBi" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="MoTa" class="form-label fw-bold"></label>
                        <textarea asp-for="MoTa" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="MoTa" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3 form-check">
                        <input asp-for="IsAvailable" class="form-check-input" />
                        <label asp-for="IsAvailable" class="form-check-label">Đang trống</label>
                    </div>
                    
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-warning">
                            <i class="fas fa-save"></i> Cập nhật
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Quay lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}