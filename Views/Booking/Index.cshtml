@model List<QLPhongHoc.Models.Booking>

@{
    ViewData["Title"] = "Lịch đặt phòng của tôi";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-6">
            <h2><i class="fas fa-calendar-alt"></i> Lịch đặt phòng của tôi</h2>
        </div>
        <div class="col-md-6 text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i> Đặt phòng mới
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> Bạn chưa có lịch đặt phòng nào.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Phòng học</th>
                        <th>Ngày đặt</th>
                        <th>Thời gian</th>
                        <th>Mục đích</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.RoomId</td>
                            <td>@item.BookingDate.ToString("dd/MM/yyyy")</td>
                            <td>@item.StartTime.ToString("HH:mm") - @item.EndTime.ToString("HH:mm")</td>
                            <td>@item.Purpose</td>
                            <td>
                                @if (item.Status == "Pending")
                                {
                                    <span class="badge bg-warning">Chờ duyệt</span>
                                }
                                else if (item.Status == "Approved")
                                {
                                    <span class="badge bg-success">Đã duyệt</span>
                                }
                                else if (item.Status == "Rejected")
                                {
                                    <span class="badge bg-danger">Từ chối</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã hủy</span>
                                }
                            </td>
                            <td>
                                @if (item.Status == "Pending")
                                {
                                    <form asp-action="Cancel" method="post" style="display:inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc muốn hủy đặt phòng này?')">
                                            <i class="fas fa-times"></i> Hủy
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>