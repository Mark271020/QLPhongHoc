@model List<QLPhongHoc.Models.Booking>

@{
    ViewData["Title"] = "Quản lý đặt phòng";
}

<div class="container">
    <h2><i class="fas fa-tasks"></i> Quản lý đặt phòng</h2>
    
    <div class="table-responsive mt-4">
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Người đặt</th>
                    <th>Phòng học</th>
                    <th>Ngày đặt</th>
                    <th>Thời gian</th>
                    <th>Mục đích</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.UserId</td>
                        <td>@item.RoomId</td>
                        <td>@item.BookingDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.StartTime.ToString("HH:mm") - @item.EndTime.ToString("HH:mm")</td>
                        <td>@item.Purpose</td>
                        <td>
                            @if (item.Status == "Pending")
                            {
                                <span class="badge bg-warning">Chờ duyệt</span>
                            }
                            else if (item.Status == "Approved")
                            {
                                <span class="badge bg-success">Đã duyệt</span>
                            }
                            else if (item.Status == "Rejected")
                            {
                                <span class="badge bg-danger">Từ chối</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Đã hủy</span>
                            }
                        </td>
                        <td>
                            @if (item.Status == "Pending")
                            {
                                <form asp-action="Approve" method="post" style="display:inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="fas fa-check"></i> Duyệt
                                    </button>
                                </form>
                                <form asp-action="Reject" method="post" style="display:inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="fas fa-times"></i> Từ chối
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>