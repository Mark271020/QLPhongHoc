@{
    ViewData["Title"] = "Trang chủ";
    var stats = Model as Dictionary<string, object> ?? new Dictionary<string, object>();
    
    int totalRooms = 0;
    int availableRooms = 0;
    int unavailableRooms = 0;
    int totalCapacity = 0;
    double avgCapacity = 0;
    
    if (stats.ContainsKey("TotalRooms")) totalRooms = Convert.ToInt32(stats["TotalRooms"]);
    if (stats.ContainsKey("AvailableRooms")) availableRooms = Convert.ToInt32(stats["AvailableRooms"]);
    if (stats.ContainsKey("UnavailableRooms")) unavailableRooms = Convert.ToInt32(stats["UnavailableRooms"]);
    if (stats.ContainsKey("TotalCapacity")) totalCapacity = Convert.ToInt32(stats["TotalCapacity"]);
    if (stats.ContainsKey("AverageCapacity")) avgCapacity = Convert.ToDouble(stats["AverageCapacity"]);
}

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold mb-3" style="color: #2d3748;">
        <i class="fas fa-chalkboard-user me-3" style="color: #4f46e5;"></i>Quản lý phòng học
    </h1>
    <p class="lead" style="color: #4b5563;">Hệ thống quản lý phòng học hiện đại, dễ sử dụng</p>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center p-4">
                <div class="bg-primary bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                    <i class="fas fa-building fa-2x text-primary"></i>
                </div>
                <h3 class="display-5 fw-bold mb-2" style="color: #1e293b;">@totalRooms</h3>
                <p class="mb-0" style="color: #64748b;">Tổng số phòng</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center p-4">
                <div class="bg-success bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                    <i class="fas fa-check-circle fa-2x text-success"></i>
                </div>
                <h3 class="display-5 fw-bold mb-2" style="color: #1e293b;">@availableRooms</h3>
                <p class="mb-0" style="color: #64748b;">Phòng trống</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center p-4">
                <div class="bg-danger bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                    <i class="fas fa-user-graduate fa-2x text-danger"></i>
                </div>
                <h3 class="display-5 fw-bold mb-2" style="color: #1e293b;">@unavailableRooms</h3>
                <p class="mb-0" style="color: #64748b;">Đang sử dụng</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center p-4">
                <div class="bg-info bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                    <i class="fas fa-users fa-2x text-info"></i>
                </div>
                <h3 class="display-5 fw-bold mb-2" style="color: #1e293b;">@totalCapacity</h3>
                <p class="mb-0" style="color: #64748b;">Tổng sức chứa</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-6">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body p-4">
                <h3 class="h4 fw-bold mb-4" style="color: #1e293b;">
                    <i class="fas fa-star me-2" style="color: #f59e0b;"></i>Tính năng nổi bật
                </h3>
                <ul class="list-unstyled mb-0">
                    <li class="mb-3 d-flex align-items-start">
                        <i class="fas fa-check-circle me-3 mt-1" style="color: #10b981;"></i>
                        <span style="color: #334155;">Quản lý phòng học trực tuyến</span>
                    </li>
                    <li class="mb-3 d-flex align-items-start">
                        <i class="fas fa-check-circle me-3 mt-1" style="color: #10b981;"></i>
                        <span style="color: #334155;">Đặt phòng linh hoạt, dễ dàng</span>
                    </li>
                    <li class="mb-3 d-flex align-items-start">
                        <i class="fas fa-check-circle me-3 mt-1" style="color: #10b981;"></i>
                        <span style="color: #334155;">Thống kê chi tiết, trực quan</span>
                    </li>
                    <li class="mb-3 d-flex align-items-start">
                        <i class="fas fa-check-circle me-3 mt-1" style="color: #10b981;"></i>
                        <span style="color: #334155;">Giao diện thân thiện, hiện đại</span>
                    </li>
                    <li class="mb-3 d-flex align-items-start">
                        <i class="fas fa-check-circle me-3 mt-1" style="color: #10b981;"></i>
                        <span style="color: #334155;">Phân quyền người dùng rõ ràng</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body p-4">
                <h3 class="h4 fw-bold mb-4" style="color: #1e293b;">
                    <i class="fas fa-chart-line me-2" style="color: #3b82f6;"></i>Thống kê nhanh
                </h3>
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span style="color: #475569;">Phòng trống</span>
                        <span class="fw-bold" style="color: #1e293b;">@availableRooms / @totalRooms</span>
                    </div>
                    <div class="progress" style="height: 8px; background-color: #e2e8f0;">
                        @{
                            double availablePercent = totalRooms > 0 ? (availableRooms * 100.0 / totalRooms) : 0;
                        }
                        <div class="progress-bar bg-success" style="width: @availablePercent%;"></div>
                    </div>
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span style="color: #475569;">Phòng đang sử dụng</span>
                        <span class="fw-bold" style="color: #1e293b;">@unavailableRooms / @totalRooms</span>
                    </div>
                    <div class="progress" style="height: 8px; background-color: #e2e8f0;">
                        @{
                            double unavailablePercent = totalRooms > 0 ? (unavailableRooms * 100.0 / totalRooms) : 0;
                        }
                        <div class="progress-bar bg-danger" style="width: @unavailablePercent%;"></div>
                    </div>
                </div>
                <div class="pt-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span style="color: #475569;">Sức chứa trung bình</span>
                        <span class="fw-bold" style="color: #1e293b;">@avgCapacity.ToString("F1") học viên/phòng</span>
                    </div>
                    <hr class="my-3" style="background-color: #e2e8f0;">
                    <div class="d-flex justify-content-between">
                        <span style="color: #475569;">Hiệu suất sử dụng</span>
                        <span class="fw-bold" style="color: #1e293b;">
                            @{
                                double usagePercent = totalRooms > 0 ? (unavailableRooms * 100.0 / totalRooms) : 0;
                            }
                            @usagePercent.ToString("F1")%
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="text-center">
    <a asp-controller="PhongHoc" asp-action="Index" class="btn btn-primary btn-lg px-5 me-3">
        <i class="fas fa-building me-2"></i>Xem danh sách phòng
    </a>
    @if (User.Identity.IsAuthenticated)
    {
        <a asp-controller="Booking" asp-action="Create" class="btn btn-outline-primary btn-lg px-5">
            <i class="fas fa-calendar-plus me-2"></i>Đặt phòng ngay
        </a>
    }
    else
    {
        <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-primary btn-lg px-5">
            <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập để đặt phòng
        </a>
    }
</div>

<style>
    .card {
        transition: transform 0.2s;
    }
    
    .card:hover {
        transform: translateY(-3px);
    }
    
    .progress {
        border-radius: 10px;
        overflow: hidden;
    }
    
    .btn-primary {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        border: none;
    }
    
    .btn-primary:hover {
        opacity: 0.9;
    }
    
    .btn-outline-primary {
        border: 2px solid #4f46e5;
        color: #4f46e5;
    }
    
    .btn-outline-primary:hover {
        background: #4f46e5;
        color: white;
        border-color: #4f46e5;
    }
    
    .bg-primary.bg-opacity-10 {
        background-color: rgba(79, 70, 229, 0.1) !important;
    }
    
    .bg-success.bg-opacity-10 {
        background-color: rgba(16, 185, 129, 0.1) !important;
    }
    
    .bg-danger.bg-opacity-10 {
        background-color: rgba(239, 68, 68, 0.1) !important;
    }
    
    .bg-info.bg-opacity-10 {
        background-color: rgba(59, 130, 246, 0.1) !important;
    }
</style>